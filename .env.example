# =============================================================================
# RhizoDelta Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Docker Compose and Spring Boot both read from this file.
# =============================================================================

# --- Neo4j Docker Image ---
NEO4J_IMAGE_TAG=5.22
NEO4J_CONTAINER_NAME=rhizodelta-neo4j

# --- Neo4j Ports (host-side, bound to 127.0.0.1) ---
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- Neo4j Authentication ---
# NEO4J_AUTH is used by the Neo4j Docker container (format: username/password).
# If the password contains '/', use Neo4j's built-in env vars instead:
#   NEO4J_AUTH=none  (disable auth)
#   Or set NEO4J_INITIAL_PASSWORD via Neo4j container env.
NEO4J_AUTH=neo4j/change-me-before-use

# NEO4J_USERNAME and NEO4J_PASSWORD are used by Spring Data Neo4j.
# Keep them consistent with NEO4J_AUTH above.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-before-use

# --- Neo4j Connection URI (used by Spring Data Neo4j) ---
NEO4J_URI=bolt://localhost:7687

# --- Neo4j Memory (Docker container) ---
NEO4J_HEAP_INIT=512M
NEO4J_HEAP_MAX=512M
