  },
  "description": "RhizoDelta AI orchestration cost & latency overview. Backed by Micrometer metrics emitted by MeteredChatLanguageModel and SweeperMetrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Token consumption rate per model (input + output combined). Spikes here translate directly to LLM cost.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "tokens/s",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "sum by (model) (rate(ai_llm_tokens_total[5m]))",
          "legendFormat": "{{model}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "AI Token Rate by Model",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "P50 / P95 / P99 latency of LLM calls grouped by purpose (SUMMARY / ROUTING / QUALITY / EMBEDDING).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "seconds",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le, purpose) (rate(ai_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{purpose}}",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, purpose) (rate(ai_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{purpose}}",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le, purpose) (rate(ai_llm_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{purpose}}",
          "range": true,
          "refId": "C"
        },
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "sum by (purpose) (rate(ai_llm_latency_seconds_sum[5m])) / sum by (purpose) (rate(ai_llm_latency_seconds_count[5m]))",
          "legendFormat": "avg {{purpose}}",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "AI Latency P50/P95/P99 by Purpose",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "LLM call error rate, grouped by exception simple name. Persistent non-zero values warrant investigation. Empty panel = no exceptions thrown (healthy).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "errors/s",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "noValue": "No errors (healthy)",
          "thresholds": { "mode": "absolute", "steps": [] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "sum by (exception) (rate(ai_llm_errors_total[5m]))",
          "legendFormat": "{{exception}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "AI Error Rate by Exception",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Sweeper candidate edges produced per stage. Empty until the sweeper-candidate-edge change ships; this panel locks in the metric contract so downstream code can wire up without changing the dashboard.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "candidates/s",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "noValue": "Awaiting sweeper-candidate-edge change",
          "thresholds": { "mode": "absolute", "steps": [] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "editorMode": "code",
          "expr": "sum by (stage) (rate(sweeper_candidates_total[5m]))",
          "legendFormat": "{{stage}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Sweeper Candidates by Stage",
      "type": "timeseries"
    }
  ],
