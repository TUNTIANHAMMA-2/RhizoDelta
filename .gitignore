# Environment variables (contains credentials)
.env

# Build output
target/

# IDE
.idea/
*.iml

# Dependencies
node_modules/

# AI tooling configs (allow project-level settings.json into git; ignore everything else under .claude/)
.claude/*
!.claude/settings.json
.codex/
.gemini/
openspec/

# Project documentation and assets
Doc/
Pic/
frontend/README.md

# Personal notes and Q&A exports (mirror the Doc/ convention)
MyResponse/
docs/reviews/answers/

# Windows Zone.Identifier metadata sidecars
*Zone.Identifier

# Local environment config
src/main/resources/application-local.yml

# Vite cache
.vite/

# Root-level slash-command harness (ccg-workflow) — not project code
/package.json
/package-lock.json

# Ad-hoc local demo scripts
k6-demo.js

# Local data (avatar uploads, etc.)
data/
